// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

enum Status {
  FILLED
  P_FILLED
  NOT_FILLED
}

enum OrderType {
  LIMIT
  MARKET
}

enum Sides {
  TAKER
  MAKER
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String
  age      Int?
  orders   Order[]
  fills    Fill[]
}

model Stock {
  id     Int     @id @default(autoincrement())
  title  String  @unique
  symbol String?
  orders Order[]
  fills  Fill[]
}

model Order {
  id        Int       @id @default(autoincrement())
  side      Sides
  type      OrderType
  price     Int?
  qty       Int
  fillesQty Int
  status    Status
  stockId   Int
  stock     Stock     @relation(fields: [stockId], references: [id])
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  creaedAt  DateTime  @default(now())
  fills     Fill[]
}

model Fill {
  id              Int       @id @default(autoincrement())
  asset           String
  stock           Stock     @relation(fields: [asset], references: [title])
  qty             Int
  side            Sides
  type            OrderType
  userId          Int
  user            User      @relation(fields: [userId], references: [id])
  price           Int
  originalOrderId Int
  order           Order     @relation(fields: [originalOrderId], references: [id])
  createdAt       DateTime  @default(now())
}
