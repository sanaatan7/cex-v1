// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

enum Sides {
  BUYER
  SELLER
}

enum OrderTypes {
  LIMIT
  MARKET
}

enum OrderStatus {
  FILLED
  P_FILLED
  NOT_FILLED
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int      @id @default(autoincrement())
  username String   @unique
  password String
  age      Int?
  orders   Orders[]
  fills    Fills[]
}

model Stocks {
  id     Int      @id @default(autoincrement())
  title  String   @unique
  symbol String?
  orders Orders[]
  fills  Fills[]
}

model Orders {
  id        Int         @id @default(autoincrement())
  side      Sides
  type      OrderTypes
  price     Int?
  qty       Int
  filledQty Int
  status    OrderStatus
  createdAt DateTime    @default(now())
  stocksId  Int
  user      User        @relation(fields: [userId], references: [id])
  userId    Int
  stocks    Stocks      @relation(fields: [stocksId], references: [id])
  fills     Fills[]
}

model Fills {
  id              Int        @id @default(autoincrement())
  qty             Int
  side            Sides
  type            OrderTypes
  userId          Int
  user            User       @relation(fields: [userId], references: [id])
  price           Int
  asset           String
  stock           Stocks     @relation(fields: [asset], references: [title])
  originalOrderId Int
  order           Orders     @relation(fields: [originalOrderId], references: [id])
  createdAt       DateTime   @default(now())
}
